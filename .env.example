# API Configuration
# Local (macOS): native host Postgres -> use host.docker.internal
# VPS: standalone Postgres container (api/scripts/docker-compose.yml) -> also host.docker.internal:5432
SQLALCHEMY_DATABASE_URL="postgresql://postgres:ViKram%232026@host.docker.internal:5432/app_db?options=-csearch_path%3Daadikarta_db"
REDIS_URL=redis://redis:6379/0

# NOTE: VITE_API_URL is NOT read from here anymore — it is set per environment in the
# compose overlays (docker-compose.local.yml -> localhost, docker-compose.vps.yml -> api.aadikarta.org).

# MiroTalk Configuration
MIROTALK_JWT_SECRET=your_jwt_secret
MIROTALK_API_KEY_SECRET=your_api_key_secret

# Vedic Rishi AstroAPI (Kundli generation) — get a token at https://astroapi.dev/signup
ASTROAPI_BASE_URL=https://astroapi.dev/api
ASTROAPI_TOKEN=bced04486591a67742c3041ea1a6819e5a9b6d8d

# Email (transactional emails via Resend: signup verification, password reset, welcome, batch notifications)
# Create a key at https://resend.com/api-keys.
# MAIL_FROM must be on a domain/subdomain verified in Resend. We send from the
# dedicated sending subdomain mail.aadikarta.org to isolate sending reputation
# from the root domain. SUPPORT_EMAIL stays on the root domain, which has a real
# inbox to receive replies.
RESEND_API_KEY=re_fZg7ryhA_4frtzwYqbjxmUtyRY7Sd7Kta
MAIL_FROM=no-reply@mail.aadikarta.org
MAIL_FROM_NAME=Aadikarta
# Used inside email templates (links + branding)
APP_NAME=Aadikarta
FRONTEND_URL=https://aadikarta.org
SUPPORT_EMAIL=support@aadikarta.org
