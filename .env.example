# API Configuration
# Local (macOS): native host Postgres -> use host.docker.internal
# VPS: standalone Postgres container (api/scripts/docker-compose.yml) -> also host.docker.internal:5432
SQLALCHEMY_DATABASE_URL="postgresql://postgres:<db_password>@host.docker.internal:5432/app_db?options=-csearch_path%3Daadikarta_db"
REDIS_URL=redis://redis:6379/0

# JWT signing secret — REQUIRED. The API refuses to start if this is unset/empty.
# Generate a strong value with: openssl rand -hex 32
# Keep it stable across deploys; changing it invalidates all existing user sessions.
JWT_SECRET_KEY=

# NOTE: VITE_API_URL is NOT read from here anymore — it is set per environment in the
# compose overlays (docker-compose.local.yml -> localhost, docker-compose.vps.yml -> api.aadikarta.org).

# MiroTalk Configuration
MIROTALK_JWT_SECRET=your_jwt_secret
MIROTALK_API_KEY_SECRET=your_api_key_secret

# Vedic Rishi AstroAPI (Kundli generation) — get a token at https://astroapi.dev/signup
ASTROAPI_BASE_URL=https://astroapi.dev/api
ASTROAPI_TOKEN=your_astroapi_token

# Email (transactional emails via Resend: signup verification, password reset, welcome, batch notifications)
# Create a key at https://resend.com/api-keys.
# MAIL_FROM must be on a domain/subdomain verified in Resend. Currently the root
# domain aadikarta.org is the verified sending domain. (If you later verify the
# dedicated subdomain mail.aadikarta.org for reputation isolation, switch MAIL_FROM
# to no-reply@mail.aadikarta.org.) SUPPORT_EMAIL stays on the root domain.
RESEND_API_KEY=your_resend_api_key
MAIL_FROM=no-reply@aadikarta.org
MAIL_FROM_NAME=Aadikarta
# Used inside email templates (links + branding)
APP_NAME=Aadikarta
FRONTEND_URL=https://aadikarta.org
SUPPORT_EMAIL=support@aadikarta.org

# WAPlex (WhatsApp gateway) inbound webhook — optional but recommended.
# The waplex library has no built-in signature check for inbound webhook
# calls, so we embed this as a query-string secret in the webhook URL we
# register during provisioning, and verify it on every inbound POST.
# Generate with: openssl rand -hex 24
# If you set this AFTER already connecting WhatsApp, disconnect and
# reconnect once so wa-platform re-registers the webhook URL with the secret.
WAPLEX_WEBHOOK_SECRET=
