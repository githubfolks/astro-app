{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "build": "node scripts/generate-sitemap.js ; tsc && vite build && (node scripts/prerender.cjs || echo '[prerender] Skipped due to error — deploy continues')",
    "sitemap": "node scripts/generate-sitemap.js",
    "preview": "vite preview",
    "mobile:build": "tsc && vite build --mode mobile",
    "mobile:sync": "npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:run": "npm run mobile:build && npm run mobile:sync"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.5.6",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.1",
    "terser": "^5.48.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.2.4",
    "vite-plugin-prerender": "^1.0.8",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@types/aos": "^3.0.7",
    "aos": "^2.3.4",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.11.0",
    "tailwind-merge": "^3.4.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
